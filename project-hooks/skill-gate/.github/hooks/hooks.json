{
    "version": 1,
    "hooks": {
        "userPromptSubmitted": [
            {
                "type": "command",
                "bash": "node .github/hooks/skill-gate-copilot.mjs userPromptSubmitted",
                "powershell": "node .github/hooks/skill-gate-copilot.mjs userPromptSubmitted",
                "timeoutSec": 5
            }
        ],
        "preToolUse": [
            {
                "type": "command",
                "bash": "node .github/hooks/skill-gate-copilot.mjs preToolUse",
                "powershell": "node .github/hooks/skill-gate-copilot.mjs preToolUse",
                "timeoutSec": 5
            }
        ],
        "postToolUse": [
            {
                "type": "command",
                "bash": "node .github/hooks/skill-gate-copilot.mjs postToolUse",
                "powershell": "node .github/hooks/skill-gate-copilot.mjs postToolUse",
                "timeoutSec": 5
            }
        ]
    }
}
